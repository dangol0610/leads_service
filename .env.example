# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=leads_service
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Connection pool
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_RECYCLE=3600
DB_POOL_PRE_PING=true

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_OUTBOX_TOPIC=leads.events.v1
KAFKA_POLL_INTERVAL=5
KAFKA_CONSUMER_TOPIC=lead_moderation.events.v1
KAFKA_CONSUMER_GROUP_ID=leads-moderation-consumer
KAFKA_POLL_TIMEOUT_MS=1000

# Logging
LOGURU_LEVEL=INFO
